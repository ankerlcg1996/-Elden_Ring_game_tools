<UserControl x:Class="TarnishedTool.Views.Tabs.PlayerTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:converters="clr-namespace:TarnishedTool.Converters"
             xmlns:controls="clr-namespace:TarnishedTool.Controls"
             xmlns:xcad="http://schemas.xceed.com/wpf/xaml/avalondock"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="600">
    <UserControl.Resources>
        <converters:BooleanAndConverter x:Key="BooleanAndConverter" />
        <xcad:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="生命：" Grid.Column="0" VerticalAlignment="Center" />
                <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="5,0,0,0">
                    <xctk:IntegerUpDown x:Name="HealthUpDown"
                                        Value="{Binding CurrentHp}"
                                        TextAlignment="Center"
                                        Width="70"
                                        IsEnabled="{Binding AreOptionsEnabled}"
                                        BorderBrush="#3F3F46" />
                    <TextBlock Text="{Binding CurrentMaxHp, StringFormat=Max: {0}}"
                               Width="60"
                               VerticalAlignment="Center"
                               Margin="7,0,0,0" />
                    <CheckBox
                        Content="锁定 HP"
                        ToolTip="锁定当前 HP，类似 ERTool 的满血/1血切换"
                        IsChecked="{Binding IsHpLocked}"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="3,0,4,0"
                        Width="67"
                        />
                    <Button
                        Content="RFBS"
                        Command="{Binding SetRfbsCommand}"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="7,0,0,0"
                        Width="40" />
                    <Button
                        Command="{Binding SetMaxHpCommand}"
                        Content="最大 HP"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="7,0,0,0"
                        Width="55" />
                    <Button
                        Command="{Binding DieCommand}"
                        Content="死亡"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="7,0,0,0"
                        Width="30" />
                    <TextBox Width="50" Height="20"
                                        Margin="7,0,0,0"
                                        Text="{Binding CustomHp, UpdateSourceTrigger=PropertyChanged}"
                                        FontSize="11"
                                        Padding="-0.2"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        MaxLength="5"
                                        />
                    <Button
                        Command="{Binding SetCustomHpCommand}"
                        Content="设置自定义 HP"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        Margin="7,0,0,0"
                        Width="95" />
                    
                    <Border Background="#3498db"
                            CornerRadius="10"
                            Width="12"
                            Height="12"
                            Margin="5,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="以 % 结尾表示百分比"
                            ToolTipService.InitialShowDelay='100'>
                        <TextBlock Text="i"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="10" />
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Margin="0,10,0,10" BorderThickness="1" BorderBrush="#333" CornerRadius="3">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="35" />
                        <RowDefinition Height="35" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <UniformGrid Grid.Row="0" Grid.Column="0" Rows="1" Columns="2">
                        <Button Content="保存位置 1"
                                Command="{Binding SavePositionCommand}"
                                CommandParameter="0"
                                Margin="0,0,5,5"
                                IsEnabled="{Binding AreOptionsEnabled}" />

                        <Button Content="恢复位置 1"
                                Command="{Binding RestorePositionCommand}"
                                CommandParameter="0"
                                Margin="5,0,0,5">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="IsPos1Saved" />
                                    <Binding Path="AreOptionsEnabled" />
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                    </UniformGrid>


                    <StackPanel Grid.Row="0" Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="10,0,0,5">


                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="包含状态"
                                      IsChecked="{Binding IsStateIncluded}" />

                            <Border Background="#3498db"
                                    CornerRadius="10"
                                    Width="12"
                                    Height="12"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="保存位置时记忆 HP/耐力"
                                    ToolTipService.InitialShowDelay='100'>
                                <TextBlock Text="i"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           FontSize="10" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Grid.Column="0" Rows="1" Columns="2">
                        <Button Content="保存位置 2"
                                Command="{Binding SavePositionCommand}"
                                CommandParameter="1"
                                Margin="0,5,5,0"
                                IsEnabled="{Binding AreOptionsEnabled}" />

                        <Button Content="恢复位置 2"
                                Command="{Binding RestorePositionCommand}"
                                CommandParameter="1"
                                Margin="5,5,0,0">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="IsPos2Saved" />
                                    <Binding Path="AreOptionsEnabled" />
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                    </UniformGrid>
                    
                    <CheckBox Grid.Row="1" Grid.Column="1" Content="玩家位置"
                              Margin="10,5,0,0"
                              IsChecked="{Binding ShowPlayerLocation}" />

                    <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                            Visibility="{Binding ShowPlayerLocation, Converter={StaticResource BoolToVis}}"
                            Margin="20, 0, 0, 0">
                        <controls:CoordinateDisplay DataContext="{Binding MapLocation}" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <CheckBox Content="不死"
                              IsChecked="{Binding IsNoDeathEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="无伤"
                              IsChecked="{Binding IsNoDamageEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="耐力无限"
                              IsChecked="{Binding IsInfiniteStaminaEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="消耗品无限"
                              IsChecked="{Binding IsInfiniteConsumablesEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="箭矢无限"
                              IsChecked="{Binding IsInfiniteArrowsEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="FP 无限"
                              IsChecked="{Binding IsInfiniteFpEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="生命回复"
                              ToolTip="每 tick 回复 3.3% 最大 HP"
                              IsChecked="{Binding IsHotEnabled}"
                              Margin="0,2" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <CheckBox Content="无受击"
                              IsChecked="{Binding IsNoHitEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="一击必杀"
                              IsChecked="{Binding IsOneShotEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="削韧无限"
                              IsChecked="{Binding IsInfinitePoiseEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="静默"
                              IsChecked="{Binding IsSilentEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="隐藏"
                              IsChecked="{Binding IsHiddenEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="快速死亡"
                              IsChecked="{Binding IsFasterDeathEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="FP 回复"
                              ToolTip="每 tick 回复 3.3% 最大 FP"
                              IsChecked="{Binding IsFpRegenEnabled}"
                              Margin="0,2" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="10, 0, 0, 0">
                    <CheckBox Content="加载时设置 RFBS"
                              IsChecked="{Binding IsSetRfbsOnLoadEnabled}"
                              Margin="0, 2" />
                    <CheckBox Content="敌人不掉卢恩"
                              IsChecked="{Binding IsNoRuneGainEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="死亡不掉卢恩弧"
                              IsChecked="{Binding IsNoRuneArcLossEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="死亡不掉卢恩"
                              IsChecked="{Binding IsNoRuneLossEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="死亡不推进时间"
                              IsChecked="{Binding IsNoTimePassOnDeathEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="任意地点骑马"
                              IsChecked="{Binding IsTorrentAnywhereEnabled}"
                              Margin="0,2" />
                    <CheckBox Content="灵马不死"
                              IsChecked="{Binding IsTorrentNoDeathEnabled}"
                              Margin="0,2" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="3" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding RuneLevel, StringFormat='Rune Level: {0}'}" FontWeight="Bold" />

            </Grid>
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="5,0,0,0">
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="VigorUpDown"
                                            Value="{Binding Vigor}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46"
                                            Tag="Vigor" />
                        <TextBlock Text="生命" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="MindUpDown"
                                            Value="{Binding Mind}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Mind"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="集中" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="EnduranceUpDown"
                                            Value="{Binding Endurance}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Endurance"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="耐力" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="StrengthUpDown"
                                            Value="{Binding Strength}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Strength"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="力量" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="DexterityUpDown"
                                            Value="{Binding Dexterity}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Dexterity"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="灵巧" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                </StackPanel>
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="IntelligenceUpDown"
                                            Value="{Binding Intelligence}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Intelligence"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="智力" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="FaithUpDown"
                                            Value="{Binding Faith}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Faith"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="信仰" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>


                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="ArcaneUpDown"
                                            Value="{Binding Arcane}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="1"
                                            Maximum="99"
                                            Grid.Column="0"
                                            Tag="Arcane"
                                            IsEnabled="{Binding AreOptionsEnabled}"
                                            BorderBrush="#3F3F46" />
                        <TextBlock Text="感应" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="ScaduUpDown"
                                            Value="{Binding Scadu}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="0"
                                            Maximum="20"
                                            Grid.Column="0"
                                            BorderBrush="#3F3F46">
                            <xctk:IntegerUpDown.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="AreOptionsEnabled" />
                                    <Binding Path="IsDlcAvailable" />
                                </MultiBinding>
                            </xctk:IntegerUpDown.IsEnabled>
                        </xctk:IntegerUpDown>

                        <TextBlock Text="幽影树" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <xctk:IntegerUpDown x:Name="SpiritAshUpDown"
                                            Value="{Binding SpiritAsh}"
                                            TextAlignment="Center"
                                            Width="80"
                                            Minimum="0"
                                            Maximum="10"
                                            Grid.Column="0"
                                            BorderBrush="#3F3F46">
                            <xctk:IntegerUpDown.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="AreOptionsEnabled" />
                                    <Binding Path="IsDlcAvailable" />
                                </MultiBinding>
                            </xctk:IntegerUpDown.IsEnabled>
                        </xctk:IntegerUpDown>
                        <TextBlock Text="骨灰" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </Grid>

                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <xctk:IntegerUpDown
                            Value="{Binding Runes}"
                            TextAlignment="Center"
                            Width="100"
                            Minimum="0"
                            Maximum="999999999"
                            DefaultValue="10000"

                            IsEnabled="{Binding AreOptionsEnabled}"
                            BorderBrush="#3F3F46" />

                        <Button Content="给予卢恩"
                                Command="{Binding GiveRunesCommand}"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Margin="10,0,0,0"
                                Width="100"
                                Height="25" />

                    </StackPanel>

                    <Button Content="卢恩弧"
                            Width="150"
                            Margin="0, 20, 0,0"
                            Command="{Binding ApplyRuneArcCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}">
                    </Button>
                    <Button Content="重置角色"
                            Width="150"
                            Margin="0, 15, 0,0"
                            Command="{Binding RestCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}">
                    </Button>
                    <CheckBox Content="休息时重置敌人"
                              Width="150"
                              Margin="0, 10, 0,0"
                              IsChecked="{Binding IsResetWorldIncluded}">
                    </CheckBox>
                </StackPanel>
            </Grid>


            <Border Grid.Row="5" Margin="0,15,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Width="200">
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <xctk:DoubleUpDown x:Name="SpeedUpDown"
                                               Value="{Binding PlayerSpeed}"
                                               TextAlignment="Center"
                                               Width="80"
                                               Minimum="0"
                                               Maximum="10"
                                               Increment="0.50"
                                               FormatString="F2"
                                               Grid.Column="0"

                                               IsEnabled="{Binding AreOptionsEnabled}"
                                               BorderBrush="#3F3F46" />
                            <TextBlock Text="玩家速度" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <xctk:IntegerUpDown x:Name="NewGameUpDown"
                                                Value="{Binding NewGame}"
                                                TextAlignment="Center"
                                                Width="80"
                                                Minimum="0"
                                                Maximum="9"
                                                Grid.Column="0"
                                                IsEnabled="{Binding AreOptionsEnabled}"
                                                BorderBrush="#3F3F46" />
                            <TextBlock Text="新游戏" Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Border Grid.Column="2"
                                    Background="#3498db"
                                    CornerRadius="10"
                                    Width="12"
                                    Height="12"
                                    Margin="15,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="若你已在该区域，需要重载一次才能更新菲雅的英雄"
                                    ToolTipService.InitialShowDelay='100'>
                                <TextBlock Text="i"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="Bold"
                                           FontSize="10" />
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Column="1"
                          Margin="5,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0">
                                <CheckBox Content="记忆速度"
                                          IsChecked="{Binding IsRememberSpeedEnabled}"
                                          Margin="0,2" />

                                <Border
                                    Background="#3498db"
                                    CornerRadius="10"
                                    Width="12"
                                    Height="12"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="重启应用后保留速度设置"
                                    ToolTipService.InitialShowDelay='100'>
                                    <TextBlock Text="i"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="10" />
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0">
                                <CheckBox Content="自动设为 NG+7"
                                          IsChecked="{Binding IsAutoSetNewGameSevenEnabled}"
                                          Margin="0,2" />

                                <Border
                                    Background="#3498db"
                                    CornerRadius="10"
                                    Width="12"
                                    Height="12"
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="新开周目时自动设为新游戏+7"
                                    ToolTipService.InitialShowDelay='100'>
                                    <TextBlock Text="i"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontWeight="Bold"
                                               FontSize="10" />
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
                                <TextBlock Text="当前动画："></TextBlock>
                                <TextBlock Text="{Binding CurrentAnimation}" VerticalAlignment="Center" Width="65"
                                           TextAlignment="Right" Margin="5,-4,0,0" />
                            </StackPanel>

                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            <Border Grid.Row="6" Margin="0,15,0,0">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Orientation="Vertical">
                        <Button
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Command="{Binding SetRuneLevelOneCommand}"
                            Margin="10,10,0,0"
                            Content="设置等级 1">
                        </Button>
                        
                        <Button 
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Command="{Binding SetMaxLevelCommand}"
                            Margin="10,10,0,0"
                            Content="设置满级">
                        </Button>
                    </StackPanel>
                    
                </Grid>
              
                
                    
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>



