<UserControl x:Class="TarnishedTool.Views.Tabs.EventTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:TarnishedTool.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="500">

    <UserControl.Resources>
        <converters:BooleanAndConverter x:Key="BooleanAndConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,10">
            <StackPanel Margin="10">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="事件标记"
                               FontWeight="Bold" />

                    <Border Background="#3498db"
                            CornerRadius="10"
                            Width="12"
                            Height="12"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="通过事件 ID 读取或设置事件"
                            ToolTipService.InitialShowDelay='100'>
                        <TextBlock Text="i"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="10" />
                    </Border>
                </StackPanel>

                <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                </Grid>

                <StackPanel Orientation="Horizontal" Margin="10,10,0,0">
                    <TextBlock Text="事件 ID：" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox Width="100" Text="{Binding GetFlagId}" Margin="0,0,10,0" />

                    <Button Content="读取事件"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Padding="10,3"
                            Margin="10,0,0,0"
                            Command="{Binding GetEventCommand}" />

                    <TextBlock Text="状态：" VerticalAlignment="Center" Margin="10,0,5,0" />
                    <TextBlock Text="{Binding EventStatusText}"
                               Foreground="{Binding EventStatusColor}"
                               VerticalAlignment="Center" Margin="5,0,10,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="10,10,0,0">
                    <TextBlock Text="事件 ID：" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBox Width="100" Text="{Binding SetFlagId}" Margin="0,0,10,0" />

                    <ComboBox Width="70" SelectedIndex="{Binding FlagStateIndex}" Margin="10,0,0,0">
                        <ComboBoxItem Content="开启" />
                        <ComboBoxItem Content="关闭" />
                    </ComboBox>

                    <Button Content="设置事件"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Padding="10,3"
                            Margin="10,0,0,0"
                            Command="{Binding SetEventCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>


        <Border Grid.Row="1"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,0">
            <StackPanel Margin="10">
                <TextBlock Text="游戏进度"
                           FontWeight="Bold"
                           Margin="0,0,0,10" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Content="解锁全部质变"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Command="{Binding UnlockWhetbladesCommand}"
                            Margin="0,2" />
                    <Button Grid.Row="1" Grid.Column="0" Content="解锁全部动作"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Command="{Binding UnlockGesturesCommand}"
                            Margin="0, 5, 0,2" />

                   
                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0, 10, 0,2">
                        <Button
                            Content="解锁梅缇尔"
                            Command="{Binding UnlockMetyrCommand}"
                            Width="120"
                            Margin="10, 0, 0,2">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="AreOptionsEnabled" />
                                    <Binding Path="IsDlcAvailable" />
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                        

                        <Border Background="#3498db"
                                CornerRadius="10"
                                Width="12"
                                Height="12"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="这将完成任务并跳过前往梅缇尔前的入侵者"
                                ToolTipService.InitialShowDelay="100">
                            <TextBlock Text="i"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="10" />
                        </Border>

                    </StackPanel>

                    
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <Button Content="挑战艾尔登之兽"
                                Width="120"
                                Command="{Binding FightEldenBeastCommand}"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Margin="10, 0, 0,2">

                        </Button>

                        <Border Background="#3498db"
                                CornerRadius="10"
                                Width="12"
                                Height="12"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="需在大致区域内"
                                ToolTipService.InitialShowDelay="100">
                            <TextBlock Text="i"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="10" />
                        </Border>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                        <Button Content="挑战弗尔桑克斯"
                                Width="120"
                                Command="{Binding FightFortissaxCommand}"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Margin="10, 5, 0,2">

                        </Button>

                        <Border Background="#3498db"
                                CornerRadius="10"
                                Width="12"
                                Height="12"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="需要位于深根底层区域"
                                ToolTipService.InitialShowDelay="100">
                            <TextBlock Text="i"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="10" />
                        </Border>
                    </StackPanel>
                    <Button Grid.Row="0" Grid.Column="2" 
                            Content="给予初始圣杯瓶"
                            Command="{Binding GiveStartingFlasksCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            ></Button>
                </Grid>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,5">
            <StackPanel Margin="10">
                
                <TextBlock Text="切换标记"
                           FontWeight="Bold"
                           Margin="0,0,0,10" />
                
                
                 <StackPanel Orientation="Horizontal">

                        <Button Content="DLC 通关标记"
                                Width="120"
                                Command="{Binding ClearDlcCommand}"
                                Margin="10, 0, 0,2">
                            <Button.IsEnabled>
                                <MultiBinding Converter="{StaticResource BooleanAndConverter}">
                                    <Binding Path="AreOptionsEnabled" />
                                    <Binding Path="IsDlcAvailable" />
                                </MultiBinding>
                            </Button.IsEnabled>
                        </Button>
                     
                     <TextBlock Text="{Binding DlcClearStatusText}"
                                Width="20"
                                Foreground="{Binding DlcClearStatusColor}"
                                FontFamily="Bold"
                                VerticalAlignment="Center" Margin="10,0,0,0" />

                        <Border Background="#3498db"
                                CornerRadius="10"
                                Width="12"
                                Height="12"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                ToolTip="这是新引入的数值修正，会提高 DLC 中 Boss 和敌人的 HP。&#x0A;击败约定之王拉塔恩并进入下一周目后生效。&#x0A;该修正生效后不会消失，且为固定值，即后续周目加成百分比不变。&#x0A;该修正不影响本体 Boss 与敌人。"
                                ToolTipService.InitialShowDelay="100">
                            <TextBlock Text="i"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="10" />
                        </Border>

                    </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0, 10, 0,2">
                    <Button
                        Content="停用雪原灵庙"
                        Command="{Binding DeactivateMausoleumCommand}"
                        Width="200"
                        Margin="10, 0, 0,2"
                        IsEnabled="{Binding AreOptionsEnabled}"
                        />
                        
                    
                    <TextBlock Text="{Binding DeactivateMausoleumStatusText}"
                               Width="20"
                               Foreground="{Binding DeactivateMausoleumStatusColor}"
                               FontFamily="Bold"
                               VerticalAlignment="Center" Margin="5,0,0,0" />
                    
                </StackPanel>
            </StackPanel>
        </Border>


        <Border Grid.Row="3"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Margin="0,0,0,5">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderThickness="1"
                            BorderBrush="#444"
                            CornerRadius="3"
                            Margin="0,0,5,0">
                        <StackPanel Margin="10">
                            <TextBlock Text="附加选项"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10" />

                            <Grid Margin="10,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Vertical">
                                    <CheckBox
                                        Content="显示事件"
                                        IsChecked="{Binding IsDrawEventsEnabled}">
                                    </CheckBox>

                                    <CheckBox
                                        Content="禁用事件"
                                        IsChecked="{Binding IsDisableEventsEnabled}">

                                    </CheckBox>
                                    
                                    <CheckBox
                                        Content="事件记录器"
                                        IsChecked="{Binding IsEventLoggerEnabled}">

                                    </CheckBox>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1"
                            BorderThickness="1"
                            BorderBrush="#444"
                            CornerRadius="3"
                            Margin="5,0,0,0"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="设置时间" FontWeight="SemiBold" Margin="0,0,0,5" />

                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <Button
                                    Content="早晨"
                                    Margin="10,0,0,0"
                                    IsEnabled="{Binding AreOptionsEnabled}"
                                    Command="{Binding SetMorningCommand}" />
                                <Button
                                    Content="正午"
                                    Margin="10,0,0,0"
                                    IsEnabled="{Binding AreOptionsEnabled}"
                                    Command="{Binding SetNoonCommand}" />
                                <Button
                                    Content="黄昏"
                                    Margin="10,0,0,0"
                                    IsEnabled="{Binding AreOptionsEnabled}"
                                    Command="{Binding SetDuskCommand}" />
                                <Button
                                    Content="夜晚"
                                    Margin="10,0,0,0"
                                    IsEnabled="{Binding AreOptionsEnabled}"
                                    Command="{Binding SetNightCommand}" />
                                </StackPanel>
                        <StackPanel>
                            <TextBlock Text ="设置天气" FontWeight="SemiBold" Margin="0,15,0,0"/>
                            <ComboBox ItemsSource="{Binding WeatherTypes}"
                                      DisplayMemberPath="Name"
                                       SelectedItem="{Binding SelectedWeatherType}"
                                      Margin="0,10,0,0"/>
                            <Button Content ="设置"
                                    Margin="0,6,0,0"
                                    IsEnabled="{Binding AreOptionsEnabled}"
                                    Command="{Binding SetWeatherCommand}"/>
                        </StackPanel>
                    </StackPanel>        
                    </Border>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>


