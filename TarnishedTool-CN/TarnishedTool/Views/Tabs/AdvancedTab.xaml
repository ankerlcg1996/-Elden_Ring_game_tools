<UserControl x:Class="TarnishedTool.Views.Tabs.AdvancedTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:converters="clr-namespace:TarnishedTool.Converters"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="600">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Margin="0,5,0,0"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Padding="5">
            <StackPanel Margin="5">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="玩家特殊效果"
                               FontWeight="SemiBold" />

                    <Border Background="#3498db"
                            CornerRadius="10"
                            Width="12"
                            Height="12"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="通过 ID 添加或移除特殊效果"
                            ToolTipService.InitialShowDelay='100'>
                        <TextBlock Text="i"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="10" />
                    </Border>
                </StackPanel>

                <Grid Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="10,5,0,0">
                        <TextBlock Text="ID：" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Width="100" Text="{Binding ApplySpEffectId}" Margin="0,0,10,0" />

                        <Button Content="应用"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Padding="10,3"
                                Margin="10,0,0,0"
                                Command="{Binding ApplySpEffectCommand}" />

                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="10,5,0,0">
                        <TextBlock Text="ID：" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Width="100" Text="{Binding RemoveSpEffectId}" Margin="0,0,10,0" />

                        <Button Content="移除"
                                IsEnabled="{Binding AreOptionsEnabled}"
                                Padding="10,3"
                                Margin="10,0,0,0"
                                Command="{Binding RemoveSpEffectCommand}" />
                    </StackPanel>

                    <CheckBox Grid.Row="0" Grid.Column="1"
                              HorizontalAlignment="Right"
                              IsChecked="{Binding IsSpEffectWindowOpen}"
                              Content="显示激活特殊效果"
                              Margin="0,0,10,0" />

                    <Button Grid.Row="1" Grid.Column="1" Content="关于特殊效果"
                            Width="150"
                            Height="25"
                            Padding="10,3"
                            Margin="10,0,0,0"
                            Command="{Binding AboutSpEffectsCommand}" />
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="1" BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"
                Padding="10"
                Margin="0,10,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,15">
                    <TextBlock Text="按装备参数 ID 生成"
                               FontWeight="SemiBold" />
                    <Border Background="#3498db"
                            CornerRadius="10"
                            Width="12"
                            Height="12"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            ToolTip="该功能主要用于测试自定义/模组武器；若无此需求请使用普通物品生成"
                            ToolTipService.InitialShowDelay="100">
                        <TextBlock Text="i"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="10" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding EquipTypes}"
                              DisplayMemberPath="Key"
                              SelectedValuePath="Value"
                              Width="100"
                              Height="35"
                              VerticalContentAlignment="Center"
                              HorizontalAlignment="Left"
                              Margin="43,0,86.5,0"
                              SelectedValue="{Binding SelectedEquipType}" />

                    <TextBlock Text="装备 ID："
                               Height="20"
                               Width="60"
                               FontSize="14"
                               Margin="15,0,5,0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               TextAlignment="Right" />

                    <TextBox Text="{Binding EquipId}"
                             Height="35"
                             Width="100"
                             FontSize="14"
                             Margin="10,0,0,0"
                             VerticalContentAlignment="Center"
                             HorizontalAlignment="Center"
                             MaxLength="8" />

                    <Button Content="生成"
                            Command="{Binding SpawnWithEquipIdCommand}"
                            IsEnabled="{Binding AreOptionsEnabled}"
                            Margin="15,0,0,0"
                            HorizontalAlignment="Right"
                            Height="35"
                            Width="80" />
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="2"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"

                Padding="5">
            <StackPanel Grid.Row="2" Margin="5">
                <TextBlock
                    Text="参数补丁器"
                    FontWeight="SemiBold"
                    TextAlignment="Left" />
                <Border Background="#3498db"
                        CornerRadius="10"
                        Width="12"
                        Height="12"
                        Margin="0,-15,400,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ToolTip="临时修改游戏参数，效果持续到重启游戏或恢复默认值。"
                        ToolTipService.InitialShowDelay="100">
                    <TextBlock Text="i"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="10" />
                </Border>
                <Button Content="初始化参数补丁器"
                        Command="{Binding OpenParamEditorCommand}"
                        VerticalAlignment="Center"
                        MaxWidth="250"
                        Margin="0,5,0,0"
                        Height="50">
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                BorderThickness="1"
                BorderBrush="#333"
                CornerRadius="3"

                Padding="5">
            <StackPanel Grid.Row="2" Margin="5">
                <TextBlock
                    Text="AI"
                    FontWeight="SemiBold"
                    TextAlignment="Left" />
                
                <UniformGrid>
                    <Button Content="角色列表"
                            Command="{Binding OpenAiWindowCommand}"
                            VerticalAlignment="Center"
                            MaxWidth="250"
                            Margin="0,5,0,0"
                            Height="50">
                    </Button>
                    <Button Content="注入 AI 脚本"
                            Command="{Binding InjectScriptCommand}"
                            VerticalAlignment="Center"
                            MaxWidth="250"
                            Margin="0,5,0,0"
                            Height="50">
                    </Button>
                    
                </UniformGrid>

            </StackPanel>
        </Border>
    </Grid>


</UserControl>


